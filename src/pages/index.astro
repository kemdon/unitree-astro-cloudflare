---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { blockRegistry } from '@/lib/blocks'
import { getLocalizedValue } from '@/lib/i18n'
import { loadNavigationPages, loadSite } from '@/lib/loader'

const runtimeEnv = Astro.locals.env
const site = await loadSite(runtimeEnv)
const allPages = await loadNavigationPages(runtimeEnv)
const page = allPages.find((entry) => entry.slug === '/') ?? null
const defaultTitle = '站点尚未初始化'
const defaultDescription = '当前还没有首页内容。请先进入后台配置站点信息并创建页面。'
---

<BaseLayout
  title={page ? getLocalizedValue(page.seo.title) || defaultTitle : defaultTitle}
  description={page ? getLocalizedValue(page.seo.description) || defaultDescription : defaultDescription}
  site={site}
  currentPath={Astro.url.pathname}
>
  <div class="shell">
    {page ? (
      page.blocks.map((block) => {
        const Component = blockRegistry[block.type] as any
        return <Component {...block.props} allPages={allPages} />
      })
    ) : (
      <section class="panel empty-site-state">
        <h1>{defaultTitle}</h1>
        <p>{defaultDescription}</p>
        <div class="hero__actions">
          <a class="button button--primary" href="/admin/site">
            配置站点信息
          </a>
          <a class="button button--secondary" href="/admin/pages">
            创建首页内容
          </a>
        </div>
      </section>
    )}
  </div>
</BaseLayout>
