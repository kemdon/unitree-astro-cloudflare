---
import '@/styles/global.css'

const next = Astro.url.searchParams.get('next') || '/admin'
const error = Astro.url.searchParams.get('error')
---

<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin / Login</title>
  </head>
  <body class="admin-login-page">
    <div class="admin-wrap admin-wrap--centered">
      <section class="admin-card admin-card--wide auth-card">
        <div class="admin-header">
          <h1>后台登录</h1>
          <p class="muted">请输入账号和密码进入后台。</p>
        </div>

        {error && <p class="validation-item">用户名或密码错误，请重试。</p>}

        <form action="/api/admin/login" class="form-grid" method="post">
          <input name="next" type="hidden" value={next} />
          <div class="field">
            <label for="username">用户名</label>
            <input autocomplete="username" data-testid="login-username-input" id="username" name="username" required />
          </div>
          <div class="field">
            <label for="password">密码</label>
            <input
              autocomplete="current-password"
              data-testid="login-password-input"
              id="password"
              name="password"
              required
              type="password"
            />
          </div>
          <button class="button button--primary" data-testid="login-submit-button" type="submit">登录</button>
        </form>
      </section>
    </div>
  </body>
</html>
