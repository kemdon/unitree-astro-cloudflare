---
interface FaqItem {
  question: string
  answer: string
}

interface Props {
  title: string
  items: FaqItem[]
}

const { title, items } = Astro.props
---

<section class="block panel faq">
  <h2 class="section-title">{title}</h2>
  <div class="faq-list">
    {items.map((item) => (
      <article class="faq-item">
        <h3>{item.question}</h3>
        <p class="muted">{item.answer}</p>
      </article>
    ))}
  </div>
</section>
