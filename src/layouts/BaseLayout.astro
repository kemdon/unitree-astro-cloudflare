---
import '@/styles/global.css'
import { getLocalizedValue, isExternalLink, withLocaleParam } from '@/lib/i18n'
import type { SiteConfig } from '@/lib/schema'

interface Props {
  title: string
  description?: string
  site: SiteConfig
  currentPath?: string
}

const { title, description, site, currentPath = '/' } = Astro.props
const siteName =
  getLocalizedValue(site.siteName) || (site.brand.logoText ? getLocalizedValue(site.brand.logoText) : '') || '未命名站点'
const featuredLinks = site.featuredLinks ?? []
const footerGroups = site.footerGroups ?? []
const socialLinks = site.socialLinks ?? []
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__top">
        <div class="site-header__top-inner">
          <p>民用机器人与具身智能平台</p>
          <div class="site-header__meta">
            {site.contact.email && <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>}
            {site.contact.phone && <a href={`tel:${site.contact.phone}`}>{site.contact.phone}</a>}
          </div>
        </div>
      </div>
      <div class="site-header__inner">
        <a class="site-brand" href={withLocaleParam('/')}>
          <span class="site-brand__mark">UNITREE</span>
          <span class="site-brand__text">{siteName}</span>
        </a>
        <div class="site-header__actions">
          <nav class="site-nav">
            {site.navigation.map((item) => (
              <a aria-current={item.href === currentPath ? 'page' : undefined} href={withLocaleParam(item.href)}>
                {getLocalizedValue(item.label)}
              </a>
            ))}
          </nav>
          {featuredLinks.length > 0 && (
            <div class="site-header__cta-group">
              {featuredLinks.map((item) => (
                <a class="button button--secondary" href={isExternalLink(item.href) ? item.href : withLocaleParam(item.href)}>
                  {getLocalizedValue(item.label)}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__intro">
          <div>
            <p class="site-footer__eyebrow">Embodied Intelligence</p>
            <h2>{siteName}</h2>
            <p>{site.seo.defaultDescription}</p>
          </div>
          <div class="site-footer__contact">
            {site.contact.email && <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>}
            {site.contact.phone && <a href={`tel:${site.contact.phone}`}>{site.contact.phone}</a>}
            {site.contact.address && <p>{site.contact.address}</p>}
          </div>
        </div>
        {footerGroups.length > 0 && (
          <div class="site-footer__grid">
            {footerGroups.map((group) => (
              <section class="site-footer__group">
                <h3>{group.title}</h3>
                <ul>
                  {group.links.map((item) => (
                    <li>
                      <a href={isExternalLink(item.href) ? item.href : withLocaleParam(item.href)}>{item.label}</a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        )}
        <div class="site-footer__bottom">
          <p>{site.legalText || 'Copyright © 2016 - 2026 Unitree Robotics. All rights reserved.'}</p>
          {socialLinks.length > 0 && (
            <div class="site-footer__social">
              {socialLinks.map((item) => (
                <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
              ))}
            </div>
          )}
        </div>
      </div>
    </footer>
  </body>
</html>
